{
	"name": "@watson/db",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./schema": "./src/schema/index.ts"
	},
	"scripts": {
		"lint": "biome lint .",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "docker exec -i watson-postgres psql -U watson -d watson -v ON_ERROR_STOP=1 < seed.sql"
	},
	"dependencies": {
		"@watson/shared": "workspace:*",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.5"
	},
	"devDependencies": {
		"drizzle-kit": "^0.31.10",
		"typescript": "^5.7.3"
	}
}
