# --- Database (lokální dev přes docker compose) ---
DATABASE_URL=postgres://watson:watson@localhost:5435/watson

# --- API ---
API_PORT=8787
WEB_ORIGIN=http://localhost:5173
# Zapnout jen za spravovanou proxy, která přepisuje forwarded hlavičky.
TRUST_PROXY=0

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8787
# Pilot je výchozí invite-only. Zapněte jen pokud má být veřejná registrace skutečně povolená.
AUTH_ALLOW_SIGNUP=0
# V produkci je bez této proměnné 2FA pro zápisy adminů/vlastníků povinné.
AUTH_REQUIRE_PRIVILEGED_2FA=1
AUTH_EMAIL_FROM=Watson <auth@example.com>
REMINDER_EMAIL_FROM=Watson <reminders@example.com>
# Samostatný náhodný secret (min. 32 B) pro HMAC exportních manifestů.
BACKUP_SIGNING_SECRET=
# Samostatný náhodný secret (min. 32 B) pro odvození per-user klíčů lokální DB.
# Jeho rotace invaliduje lokální cache; serverová data zůstávají zachována.
LOCAL_DATA_ENCRYPTION_SECRET=
# Rotovatelný keyring pro mailbox OAuth/IMAP credentials:
# {"version":1,"currentKid":"mail-2026-07","keys":{"mail-2026-07":"<32B-base64url>"}}
MAIL_VAULT_KEYS_JSON=
# Magic-link odkaz do konzole POUZE v dev (CC-P0-11); v produkci se nikdy neloguje.
DEV_AUTH_LOG_LINKS=0
# Samostatný 32+ znakový bearer token pro /ops/slo (monitoring pouze server-to-server).
OPS_METRICS_TOKEN=

# --- AI (Anthropic) — doplnit ve fázi quick add ---
ANTHROPIC_API_KEY=

# --- PowerSync — doplnit ve fázi sync ---
POWERSYNC_URL=http://localhost:8080
# Produkce: JSON keyring version=1 s currentKid a keys[]; staré public-only klíče
# ponechte během overlap rotace. PowerSync a LuckyOS NESMÍ sdílet keyring.
POWERSYNC_SIGNING_KEYS_JSON=
POWERSYNC_ISSUER=watson-powersync

# --- Google Calendar — doplnit ve fázi kalendář ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Mail M1: oddělený Gmail OAuth klient (nepoužívat login client) ---
MAIL_GOOGLE_CLIENT_ID=
MAIL_GOOGLE_CLIENT_SECRET=
MAIL_GOOGLE_REDIRECT_URI=http://localhost:8787/api/mail/oauth/google/callback
# Pouze lokální/CI provider stuby; produkce vždy používá pevné Google HTTPS endpointy.
MAIL_GOOGLE_AUTH_URL=
MAIL_GOOGLE_TOKEN_URL=
MAIL_GOOGLE_API_BASE_URL=
MAIL_GOOGLE_REVOKE_URL=

# --- Notifikace — doplnit ve fázi připomínky ---
RESEND_API_KEY=
# Jen lokální/CI stub; produkce tuto hodnotu ignoruje a používá https://api.resend.com.
RESEND_API_BASE_URL=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@watson.test

# --- Zaměstnanecký modul (most na LuckyOS) ---
# Base URL produkčního/lokálního LuckyOS (broker volá /api/employee/* server-to-server).
# Nechat prázdné + LUCKYOS_MOCK=1 pro dev bez reálného LuckyOS (canned data).
LUCKYOS_BASE_URL=
LUCKYOS_MOCK=
LUCKYOS_SIGNING_KEYS_JSON=
LUCKYOS_ISSUER=watson-luckyos
