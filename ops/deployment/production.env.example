# Copy variable names into the production secrets/platform layer. Do not deploy this file
# and never replace placeholders in Git. Validate the injected environment immediately
# before release with: pnpm verify:production-config

NODE_ENV=production
DATABASE_URL=<secret-manager:watson-production-database-url>
WEB_ORIGIN=https://app.watson.example
BETTER_AUTH_URL=https://api.watson.example
AUTH_ALLOW_SIGNUP=0
AUTH_REQUIRE_PRIVILEGED_2FA=1
TRUST_PROXY=1

BETTER_AUTH_SECRET=<secret-manager:watson-auth-secret>
BACKUP_SIGNING_SECRET=<secret-manager:watson-export-signing-secret>
LOCAL_DATA_ENCRYPTION_SECRET=<secret-manager:watson-local-data-root-secret>
MAIL_VAULT_KEYS_JSON=<secret-manager:watson-mail-vault-keyring-json>
OPS_METRICS_TOKEN=<secret-manager:watson-ops-metrics-token>

AUTH_EMAIL_FROM="Watson <auth@watson.example>"
REMINDER_EMAIL_FROM="Watson <reminders@watson.example>"
RESEND_API_KEY=<secret-manager:watson-resend-api-key>
VAPID_PUBLIC_KEY=<secret-manager:watson-vapid-public-key>
VAPID_PRIVATE_KEY=<secret-manager:watson-vapid-private-key>
VAPID_SUBJECT=mailto:security@watson.example

POWERSYNC_URL=https://sync.watson.example
POWERSYNC_SIGNING_KEYS_JSON=<secret-manager:watson-powersync-keyring-json>
POWERSYNC_ISSUER=watson-powersync

# Optional feature providers. Configure both values in a pair or neither.
GOOGLE_CLIENT_ID=<secret-manager:watson-google-client-id>
GOOGLE_CLIENT_SECRET=<secret-manager:watson-google-client-secret>
ANTHROPIC_API_KEY=<secret-manager:watson-anthropic-api-key>

LUCKYOS_BASE_URL=https://people.watson.example
LUCKYOS_MOCK=0
LUCKYOS_SIGNING_KEYS_JSON=<secret-manager:watson-luckyos-keyring-json>
LUCKYOS_ISSUER=watson-luckyos
